generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  username  String
  password  String
  createdAt DateTime @default(now())
}

model Blog {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  excerpt     String
  content     String
  coverImage  String
  images      String[]  
  views       Int       @default(0)
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
}

model Comment {
  id        String        @id @default(uuid())
  author    String
  content   String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  blogId    String
  blog      Blog          @relation(fields: [blogId], references: [id], onDelete: Cascade)
}
